            </form>
            -->
            <form>
                <div class="form-group mb-3">
                    <input class="form-control" type="text" placeholder="Username" @bind="Username" required />
                </div>
                <div class="form-group text-center">
                    <button class="btn btn-primary" type="submit" value="Check In" @onclick="CheckInSubmit">Check In</button>
                </div>
                <div class="form-group text-center">
                    <button class="btn btn-primary" type="submit" value="Check Out" @onclick="CheckOutSubmit">Check Out</button>
                </div>
            </form>

        </div>
    </div>
</div>

@code {
