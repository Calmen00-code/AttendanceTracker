    public string? Username { get; set; }
    public string? CurrentTime { get; set; }

    protected override async Task OnInitializedAsync()
    {
        CurrentTime = DateTime.Now.ToString();
    }

    public async void CheckInSubmit()
    {
        string route_timesheet_checkin = APPLICATION_API_URL_DEPLOYMENT + "checkin/" + Username + "/" + CurrentTime;
        var content = new StringContent(string.Empty);
        // ERROR: no response after clicking checkin or checkout
        // FIXME: try posting a real object instead of string like this
        var response = await HttpClient.PostAsync(route_timesheet_checkin, content);

        if ((int) response.StatusCode == HttpResponseStatus.CREATED || 
            (int) response.StatusCode == HttpResponseStatus.ACCEPTED)
        {
            ShowAlert("Check in submitted");
        }
        else
        {
            var errorContent = response.Content.ReadAsStringAsync();
            var errorMessage = $"Error: {errorContent}";
            ShowAlert(errorMessage);
        }
        return;
    }

    public async void CheckOutSubmit()
    {
        string route_timesheet_checkout = APPLICATION_API_URL_DEPLOYMENT + "checkout/" + Username + "/" + CurrentTime;
