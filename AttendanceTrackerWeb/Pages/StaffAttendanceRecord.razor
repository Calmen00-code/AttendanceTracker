                };
                */


                /*
                string dummyCheckIn = "2023-12-22T23:01:22";
                DateTime dummyDateCheckIn = DateTime.Parse(dummyCheckIn);
                staffWorkday.CheckIn = dummyDateCheckIn;

                // default CheckOut time will be the same as CheckIn,
