        }

        // Navigation.NavigateTo("admin-menu");
        // NavigationManager.NavigateTo("admin-menu");
    }

    public async void CheckOutSubmit()
    {
        StaffAPI staff = await GetStaff();
        if (staff == null)
        {
            return;
        }

        // Constructing workday object for staff, ONLY if staff is VALID
        string route_submit_workday = APPLICATION_API_URL_DEPLOYMENT + ADD_WORKDAY_RECORD;

        string alignedDateFormat = AlignDateFormat(CurrentTime);

        WorkdayRecordAPI staffWorkday = new WorkdayRecordAPI();
        DateTime alignedDateTime = DateTime.Parse(AlignDateFormat(CurrentTime));
        staffWorkday.Date = alignedDateTime;

        staffWorkday.CheckIn = alignedDateTime;
        staffWorkday.CheckOut = alignedDateTime;
        staffWorkday.StaffName = Username;

        staffWorkday.Staff = staff;

        // TODO: use PUT here
        var response_workday = await HttpClient.PostAsJsonAsync(route_submit_workday, staffWorkday);

        // var response_workday = await HttpClient.SendAsync(request);
        if ((int)response_workday.StatusCode == HttpResponseStatus.CREATED)
        {
            ShowAlert("Check in submitted");
            // TODO: report to tell user check in completed
            //       stating current check in time
            return; // this should be removed when TODO done
        }
        else
        {
            ShowAlert("Error occured");
            return;
        }

        // Navigation.NavigateTo("admin-menu");
        // NavigationManager.NavigateTo("admin-menu");
    }

    private async Task<StaffAPI> GetStaff()
    {
        string route_staff_exist = APPLICATION_API_URL_DEPLOYMENT + IS_STAFF_EXIST + Username;        
        var response = await HttpClient.GetAsync(route_staff_exist);

        if ((int)response.StatusCode == HttpResponseStatus.OK)
        {
            string route_staff = APPLICATION_API_URL_DEPLOYMENT + GET_STAFF + Username;        
            var response_staff = await HttpClient.GetAsync(route_staff);
            if ((int)response_staff.StatusCode == HttpResponseStatus.OK)
            {
                StaffAPI staff = await response_staff.Content.ReadFromJsonAsync<StaffAPI>();
                return staff;
            }
            else
            {
                ShowAlert("Could not load staff");
                return null;
            }
        }
        else
        {
            ShowAlert("User does not exist!");
            return null;
        }
    }

    // function used to align the dateTime to compatible with Database format
    private string AlignDateFormat(string dateTime)
    {
        return DateTime.Parse(dateTime).ToString("yyyy-MM-ddTHH:mm:ss");
    }

    private void ShowAlert(string message)
    {
        jsRuntime.InvokeVoidAsync("alert", message);
    }
}
