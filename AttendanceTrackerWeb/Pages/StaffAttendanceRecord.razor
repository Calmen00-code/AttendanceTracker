                    <input class="form-control" type="text" placeholder="Username" @bind="Username" required />
                </div>
                <div class="form-group text-center">
                    <button class="check-in" type="submit" value="Check In" @onclick="CheckInSubmit">Check In</button>
                </div>
                <div class="form-group text-center">
                    <button class="check-out" type="submit" value="Check Out" @onclick="CheckOutSubmit">Check Out</button>
                </div>
            </form>
        </div>
    </div>
</div>

