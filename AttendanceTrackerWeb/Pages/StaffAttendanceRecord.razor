                string dummyCheckOut = "2023-12-22T23:01:22";
                DateTime dummyDateCheckOut = DateTime.Parse(dummyCheckOut);
                staffWorkday.CheckOut = dummyDateCheckOut;
                 */

                WorkdayRecordAPI staffWorkday = new WorkdayRecordAPI();
                DateTime alignedDateTime = DateTime.Parse(AlignDateFormat(CurrentTime));
                staffWorkday.Date = alignedDateTime;

                staffWorkday.CheckIn = alignedDateTime;
                staffWorkday.CheckOut = alignedDateTime;
                staffWorkday.StaffName = Username;

                staffWorkday.Staff = staff;

                var response_workday = await HttpClient.PostAsJsonAsync(route_submit_workday, staffWorkday);

                // var response_workday = await HttpClient.SendAsync(request);
                if ((int)response_workday.StatusCode == HttpResponseStatus.CREATED)
                {
                    ShowAlert("Check in submitted");
                    // TODO: report to tell user check in completed
                    //       stating current check in time
                    return; // this should be removed when TODO done
                }
                else
                {
                    ShowAlert("Error occured");
                    return;
                }
            }
            else
            {
                ShowAlert("Could not load staff");
                return;
            }
        }
        else
